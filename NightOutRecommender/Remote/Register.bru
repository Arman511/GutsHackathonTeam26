meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: https://nos.armandev.co.uk/api/auth/register
  body: json
  auth: apikey
}

auth:apikey {
  key: x-api-key
  value: {{nos_api_key}}
  placement: header
}

body:json {
  {
    "name": "Himani",
    "username": "Himani",
    "password": "{{himani_pass}}"
  }
}

body:form-urlencoded {
  username: arman
  password: arman
}

settings {
  encodeUrl: true
  timeout: 0
}
