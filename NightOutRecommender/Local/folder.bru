meta {
  name: Local
}

auth {
  mode: oauth2
}

auth:oauth2 {
  grant_type: password
  access_token_url: http://localhost:8000/api/auth/token
  refresh_token_url: 
  username: 
  password: 
  client_id: 
  client_secret: 
  scope: 
  credentials_placement: body
  credentials_id: credentials
  token_placement: header
  token_header_prefix: Bearer
  auto_fetch_token: true
  auto_refresh_token: false
}
